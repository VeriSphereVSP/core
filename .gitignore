# Foundry
out/
cache/
broadcast/
foundry.lock
*.json

# Environment variables
.env
*.env
*.venv/

# Hardhat
artifacts/

# Logs
*.log

# Node (in case tests/scripts install tooling later)
node_modules/

# misc
modules/
objects/

# Allow tracked submodules
lib/*
# oz_v5_submodule: track the real submodule libs despite the lib/* ignore above
!lib/forge-std
!lib/openzeppelin-contracts
!lib/openzeppelin-contracts-upgradeable
!lib/prb-math

# OS
.DS_Store
.idea/
.vscode/
Thumbs.db

# misc
audits

# Generated deployment artifacts (written by deploy.sh / forge script)
# The canonical copy lives in broadcast/ and is propagated by deploy.sh.
# Do NOT commit these — they drift and cause address mismatches.
deployments/dev.json
deployments/fuji.json
broadcast/
cache/
out/

# patch_storage_layout_gate: keep storage-layout regression baselines tracked
# (the global *.json rule above would otherwise ignore them).
!script/storage-layout/baselines/*.json
